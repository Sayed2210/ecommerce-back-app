<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>We missed you — here is a discount</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333; background: #f9f9f9; margin: 0; padding: 0;">
  <div style="max-width: 600px; margin: 0 auto; background: #fff; padding: 32px;">

    <h2 style="margin-top: 0;">We miss you, {{userName}}!</h2>
    <p>Your cart is still waiting. As a thank you for coming back, use the code below for a discount on your order:</p>

    <div style="background: #f5f5f5; border: 2px dashed #ccc; text-align: center; padding: 20px; margin: 24px 0; border-radius: 4px;">
      <p style="margin: 0; font-size: 13px; color: #666;">Your discount code</p>
      <p style="margin: 8px 0 0; font-size: 28px; font-weight: bold; letter-spacing: 4px; font-family: monospace;">{{discountCode}}</p>
    </div>

    {{#if cartItems}}
    <table style="width: 100%; border-collapse: collapse; margin: 0 0 24px;">
      <thead>
        <tr style="background: #f5f5f5;">
          <th style="text-align: left; padding: 8px; font-size: 13px;">Item</th>
          <th style="text-align: center; padding: 8px; font-size: 13px;">Qty</th>
        </tr>
      </thead>
      <tbody>
        {{#each cartItems}}
        <tr style="border-bottom: 1px solid #eee;">
          <td style="padding: 8px;">{{this.variant.product.name.en}}{{#if this.variant.name}} — {{this.variant.name}}{{/if}}</td>
          <td style="padding: 8px; text-align: center;">{{this.quantity}}</td>
        </tr>
        {{/each}}
      </tbody>
      <tfoot>
        <tr>
          <td style="padding: 10px 8px; font-weight: bold;">Cart Total</td>
          <td style="padding: 10px 8px; font-weight: bold; text-align: center;">${{cartTotal}}</td>
        </tr>
      </tfoot>
    </table>
    {{/if}}

    <p style="text-align: center; margin: 28px 0;">
      <a href="{{recoveryLink}}" style="background-color: #e67e22; color: #fff; padding: 12px 28px; text-decoration: none; border-radius: 4px; font-weight: bold;">
        Claim My Discount
      </a>
    </p>

    <hr style="border: none; border-top: 1px solid #eee; margin: 24px 0;" />
    <p style="font-size: 12px; color: #999; margin: 0;">
      © {{year}} {{appName}} &nbsp;|&nbsp;
      <a href="mailto:{{supportEmail}}" style="color: #999;">{{supportEmail}}</a>
    </p>
  </div>
</body>
</html>
