<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Invoice</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333; background: #f9f9f9; margin: 0; padding: 0;">
  <div style="max-width: 600px; margin: 0 auto; background: #fff; padding: 32px;">

    <h2 style="color: #2d7a2d; margin-top: 0;">Invoice</h2>
    <p>Hi {{firstName}},</p>
    <p>Thank you for your order. Please find your invoice attached to this email.</p>

    <table style="width: 100%; border-collapse: collapse; margin: 8px 0 24px;">
      <tr>
        <td style="padding: 6px 0; color: #666;">Order Number</td>
        <td style="padding: 6px 0; font-weight: bold;">#{{orderNumber}}</td>
      </tr>
      <tr>
        <td style="padding: 6px 0; color: #666;">Total</td>
        <td style="padding: 6px 0; font-weight: bold;">${{total}}</td>
      </tr>
    </table>

    <h3 style="border-bottom: 1px solid #eee; padding-bottom: 8px;">Items Ordered</h3>
    <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px;">
      <thead>
        <tr style="background: #f5f5f5;">
          <th style="text-align: left; padding: 10px 8px; font-size: 13px;">Product</th>
          <th style="text-align: center; padding: 10px 8px; font-size: 13px;">Qty</th>
          <th style="text-align: right; padding: 10px 8px; font-size: 13px;">Price</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
        <tr style="border-bottom: 1px solid #eee;">
          <td style="padding: 10px 8px;">
            {{productName}}
            {{#if variantName}}<br><span style="font-size: 12px; color: #888;">{{variantName}}</span>{{/if}}
          </td>
          <td style="padding: 10px 8px; text-align: center;">{{quantity}}</td>
          <td style="padding: 10px 8px; text-align: right;">${{unitPrice}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    {{#if shippingAddress}}
    <h3 style="border-bottom: 1px solid #eee; padding-bottom: 8px;">Shipping Address</h3>
    <p style="margin: 0 0 24px; line-height: 1.8;">
      {{shippingAddress.streetAddress}}<br>
      {{shippingAddress.city}}{{#if shippingAddress.state}}, {{shippingAddress.state}}{{/if}} {{shippingAddress.postalCode}}<br>
      {{shippingAddress.country}}
    </p>
    {{/if}}

    <hr style="border: none; border-top: 1px solid #eee; margin: 24px 0;" />
    <p style="font-size: 12px; color: #999; margin: 0;">
      Questions? Contact us at <a href="mailto:{{supportEmail}}" style="color: #007bff;">{{supportEmail}}</a><br>
      © {{year}} {{appName}}
    </p>
  </div>
</body>
</html>
